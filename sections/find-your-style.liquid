<section class="fys">
  <!-- Header Row -->
  <div class="fys__header">
    <div class="fys__header-left">
      <h2 class="fys__title">{{ section.settings.heading | default: 'Find Your Style' }}</h2>
      <p class="fys__subtitle">{{ section.settings.subtext | default: 'Discover the pieces that define your look' }}</p>
    </div>
    <div class="fys__tabs">
      {% for block in section.blocks %}
        <button
          class="fys__tab {% if forloop.first %}fys__tab--active{% endif %}"
          data-tab-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          {{ block.settings.tab_label }}
        </button>
      {% endfor %}
    </div>
  </div>

  <!-- Content Panels -->
  <div class="fys__panels">
    {% for block in section.blocks %}
      <div class="fys__panel {% if forloop.first %}fys__panel--active{% endif %}" data-panel-index="{{ forloop.index0 }}">
        <div class="fys__panel-inner" style="background: {{ block.settings.bg_color | default: '#fce4ec' }};">

          <!-- Model Image (Left) -->
          <div class="fys__model">
            {% if block.settings.model_image != blank %}
              <img
                src="{{ block.settings.model_image | image_url: width: 600 }}"
                alt="{{ block.settings.tab_label }}"
                class="fys__model-img"
                loading="lazy"
              >
            {% endif %}
          </div>

          <!-- Right Content -->
          <div class="fys__products-area">
            {% if block.settings.style_title != blank %}
              <h3 class="fys__style-title">{{ block.settings.style_title }}</h3>
            {% endif %}

            <div class="fys__products-grid">
              {% assign collection = block.settings.collection %}
              {% if collection != blank %}
                {% for product in collection.products limit: 4 %}
                  <a href="{{ product.url }}" class="fys__product-card">
                    {% if product.featured_image != blank %}
                      <img
                        src="{{ product.featured_image | image_url: width: 300 }}"
                        alt="{{ product.title | escape }}"
                        class="fys__product-img"
                        loading="lazy"
                      >
                    {% endif %}
                    <span class="fys__product-title">{{ product.title }}</span>
                    <span class="fys__product-price">{{ product.price | money }}</span>
                  </a>
                {% endfor %}
              {% else %}
                {% for i in (1..4) %}
                  <div class="fys__product-card fys__product-card--placeholder">
                    <div class="fys__product-img-placeholder"></div>
                    <span class="fys__product-title">Product {{ i }}</span>
                  </div>
                {% endfor %}
              {% endif %}
            </div>
          </div>

        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Find Your Style",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Style"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Discover the pieces that define your look"
    }
  ],
  "blocks": [
    {
      "type": "style_tab",
      "name": "Style Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab Label",
          "default": "Luxe"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "model_image",
          "label": "Model Image"
        },
        {
          "type": "text",
          "id": "style_title",
          "label": "Style Title",
          "default": "Styles"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color",
          "default": "#fce4ec"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Find Your Style",
      "blocks": [
        { "type": "style_tab", "settings": { "tab_label": "Luxe", "style_title": "Styles", "bg_color": "#fce4ec" } },
        { "type": "style_tab", "settings": { "tab_label": "Amour", "style_title": "Styles", "bg_color": "#fce4ec" } },
        { "type": "style_tab", "settings": { "tab_label": "Mystic", "style_title": "Styles", "bg_color": "#f3e5f5" } },
        { "type": "style_tab", "settings": { "tab_label": "Celestial", "style_title": "Styles", "bg_color": "#e8eaf6" } }
      ]
    }
  ]
}
{% endschema %}

<style>
/* Section */
.fys {
  max-width: 1200px;
  margin: 0 auto;
  padding: 50px 20px;
}

/* Header */
.fys__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 30px;
  gap: 20px;
}

.fys__header-left {
  flex-shrink: 0;
}

.fys__title {
  font-size: 28px;
  font-weight: 800;
  color: #111;
  margin: 0 0 8px;
  line-height: 1.2;
}

.fys__subtitle {
  font-size: 15px;
  color: #666;
  margin: 0;
}

/* Tabs */
.fys__tabs {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.fys__tab {
  padding: 10px 24px;
  border: 1.5px solid #333;
  border-radius: 50px;
  background: #fff;
  color: #333;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.fys__tab--active {
  background: #8b0000;
  color: #fff;
  border-color: #8b0000;
}

.fys__tab:hover:not(.fys__tab--active) {
  background: #f5f5f5;
}

/* Panels */
.fys__panels {
  position: relative;
}

.fys__panel {
  display: none;
}

.fys__panel--active {
  display: block;
  animation: fysFadeIn 0.4s ease;
}

@keyframes fysFadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.fys__panel-inner {
  display: flex;
  align-items: stretch;
  border-radius: 16px;
  overflow: hidden;
  min-height: 400px;
  position: relative;
}

/* Model Image */
.fys__model {
  width: 35%;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.fys__model-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Products Area */
.fys__products-area {
  flex: 1;
  padding: 30px 40px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.fys__style-title {
  font-family: 'Allura', cursive;
  font-size: 36px;
  color: #999;
  font-weight: 400;
  text-align: center;
  margin: 0 0 20px;
}

/* Products Grid */
.fys__products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 15px;
}

.fys__product-card {
  background: #fff;
  border-radius: 10px;
  overflow: hidden;
  text-decoration: none;
  color: #333;
  text-align: center;
  padding: 12px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.fys__product-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
}

.fys__product-img {
  width: 100%;
  height: 140px;
  object-fit: contain;
  display: block;
  margin-bottom: 10px;
}

.fys__product-img-placeholder {
  width: 100%;
  height: 140px;
  background: #f0f0f0;
  border-radius: 6px;
  margin-bottom: 10px;
}

.fys__product-title {
  display: block;
  font-size: 11px;
  font-weight: 600;
  color: #333;
  line-height: 1.3;
  margin-bottom: 4px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.fys__product-price {
  display: block;
  font-size: 13px;
  font-weight: 700;
  color: #8b0000;
}

/* Responsive */
@media screen and (max-width: 900px) {
  .fys__header {
    flex-direction: column;
    align-items: flex-start;
  }

  .fys__panel-inner {
    flex-direction: column;
    min-height: auto;
  }

  .fys__model {
    width: 100%;
    height: 250px;
  }

  .fys__products-area {
    padding: 20px;
  }

  .fys__products-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 480px) {
  .fys__title {
    font-size: 22px;
  }

  .fys__tab {
    padding: 8px 16px;
    font-size: 12px;
  }

  .fys__products-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .fys__product-img {
    height: 100px;
  }

  .fys__style-title {
    font-size: 28px;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  var tabs = document.querySelectorAll(".fys__tab");
  var panels = document.querySelectorAll(".fys__panel");

  tabs.forEach(function (tab) {
    tab.addEventListener("click", function () {
      var index = this.getAttribute("data-tab-index");

      tabs.forEach(function (t) { t.classList.remove("fys__tab--active"); });
      panels.forEach(function (p) { p.classList.remove("fys__panel--active"); });

      this.classList.add("fys__tab--active");
      var targetPanel = document.querySelector('.fys__panel[data-panel-index="' + index + '"]');
      if (targetPanel) targetPanel.classList.add("fys__panel--active");
    });
  });
});
</script>
